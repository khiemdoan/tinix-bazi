{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:bin -w backendjs && npm run build -w frontend",
    "devPath": "http://localhost:3005",
    "distDir": "../frontend/dist",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "tinix-bazi",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": true,
        "execute": true,
        "sidecar": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.huyencobattu.dev",
      "icon": [],
      "externalBin": ["binaries/bazi_backend"]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "TiniX BaZi",
        "width": 1280,
        "height": 800
      }
    ]
  }
}
